# Copy to .env and edit:  cp .env.example .env
#
# === LLM (answers only — embeddings are always local & free) ===
#
# FREE DEFAULT (no .env needed): if you omit OPENAI_API_KEY and do not set USE_OLLAMA=0,
# the app uses local Ollama at http://127.0.0.1:11434/v1 . Install Ollama, run `ollama pull llama3.2`,
# then start the Ollama app or `ollama serve`.
#
# Explicit free path:
USE_OLLAMA=1
OPENAI_MODEL=llama3.2
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
#
# Cloud (paid API) — set USE_OLLAMA=0 and a real key:
# USE_OLLAMA=0
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# === Database (assessment: use a real DB when submitting) ===
# Uncomment after: docker compose up -d
# DATABASE_URL=postgresql://vectera:vectera@localhost:5432/vectera
#
# If DATABASE_URL is unset, the app uses SQLite + FAISS under ./data/ (no Docker).

# EMBEDDING_DIM=384
